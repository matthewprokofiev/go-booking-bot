# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Postgres connection string.
# In docker compose DATABASE_URL is set automatically from POSTGRES_* below.
DATABASE_URL=postgres://booking:booking@localhost:5432/booking?sslmode=disable

# Comma-separated Telegram user ids that get admin rights
ADMIN_TG_IDS=123456789,987654321

# Business timezone: all slots and bookings are shown to users in this zone
BUSINESS_TZ=Europe/Moscow

# Working hours in BUSINESS_TZ, used by the demo seed
WORK_HOURS_START=10
WORK_HOURS_END=20

# local -> slog TextHandler at Debug level, anything else -> JSONHandler at Info
APP_ENV=local

# Postgres credentials used by docker compose
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking
POSTGRES_DB=booking
POSTGRES_PORT=5432
